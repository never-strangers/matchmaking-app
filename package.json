{
  "name": "neverstrangers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check-repo": "node scripts/check-git-repo.cjs",
    "dev": "npm run check-repo && next dev",
    "build": "npm run check-repo && next build",
    "start": "next start",
    "lint": "next lint",
    "seed:demo": "node scripts/seed-demo.cjs",
    "seed:users": "node scripts/seed-e2e-users.cjs",
    "seed:events": "SEED_CONFIRM=true npx tsx scripts/seed-events.ts",
    "cleanup:events": "npx tsx scripts/cleanup-events.ts",
    "reset:events": "SEED_CONFIRM=true npx tsx scripts/cleanup-events.ts && SEED_CONFIRM=true npx tsx scripts/seed-events.ts",
    "seed:test-data": "SEED_CONFIRM=true npx tsx scripts/seed-test-data.ts",
    "cleanup:test-data": "npx tsx scripts/cleanup-test-data.ts",
    "reset:test-data": "SEED_CONFIRM=true npx tsx scripts/cleanup-test-data.ts && SEED_CONFIRM=true npx tsx scripts/seed-test-data.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "download-media": "node scripts/download-media.js",
    "seed:dating-30": "SEED_CONFIRM=true npx tsx scripts/seed-dating-event-30.ts",
    "verify:dating-matching": "npx tsx scripts/verify-dating-matching.ts",
    "seed:friends-30": "SEED_CONFIRM=true npx tsx scripts/seed-friends-event-30.ts",
    "test:pairing": "npx tsx scripts/test-pairing-logic.ts",
    "backfill:answer-eq-id": "npx tsx scripts/backfill-answer-event-question-id.ts",
    "backfill:answer-eq-id:dry": "npx tsx scripts/backfill-answer-event-question-id.ts --dry-run",
    "seed:question-templates": "SEED_CONFIRM=true npx tsx scripts/seed-question-templates.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/qrcode": "^1.5.6",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.5.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "dotenv": "^16.4.5",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.35",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.1",
    "tsx": "4.21.0",
    "typescript": "^5.3.3"
  }
}
