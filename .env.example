# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL (for invite links in scripts/seed-demo.ts)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chat Feature Flags
# Set to "false" to disable chat completely
# Default: enabled in dev, disabled in prod (fail-safe)
NEXT_PUBLIC_ENABLE_CHAT=false

# Chat Mode
# Options: "mock" | "supabase"
# Default: "mock" (uses BroadcastChannel + localStorage)
NEXT_PUBLIC_CHAT_MODE=


# Pilot Preseed Matching Demo
# When "true", /match redirects to /pilot and uses preseed profiles + local overrides
NEXT_PUBLIC_PILOT_PRESEED=false

# Optional: Add other environment variables here
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
