# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Direct Postgres URI (port 5432) for scripts that use COPY, e.g. import:wp-users
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# SUPABASE_DB_URL=  # alias for DATABASE_URL

# App URL (browser + API). Local dev is usually localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production app origin for CLI batch jobs (password resets): set so links are not localhost when NEXT_PUBLIC_APP_URL is dev.
# APP_BASE_URL=https://app.thisisneverstrangers.com
# APP_URL=  # same intent as APP_BASE_URL; either wins over NEXT_PUBLIC_APP_URL in send:password-resets

# Chat Feature Flags
# Set to "false" to disable chat completely
# Default: enabled in dev, disabled in prod (fail-safe)
NEXT_PUBLIC_ENABLE_CHAT=false

# Chat Mode
# Options: "mock" | "supabase"
# Default: "mock" (uses BroadcastChannel + localStorage)
NEXT_PUBLIC_CHAT_MODE=



# Registration Form Prefill (dev/testing)
# When "true", /register form is prefilled with random valid values. Set to "false" or omit to disable.
# NEXT_PUBLIC_PREFILL_REGISTER_FORM=true

# Optional: Add other environment variables here
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Transactional Email
# EMAIL_PROVIDER: "mock" (console log, default) | "resend" | "enveloped" (live sends)
EMAIL_PROVIDER=mock
RESEND_API_KEY=
ENVLOPED_API_KEY=
EMAIL_FROM=Never Strangers <hello@thisisneverstrangers.com>

# E2E Test mode (local only)
# Use a dedicated Supabase test project and copy these into .env.test
# E2E_TEST_MODE=true
# E2E_SHARED_SECRET=replace_with_random_secret
# PLAYWRIGHT_BASE_URL=http://localhost:3000
